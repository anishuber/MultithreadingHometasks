    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Common\Common.Diagnostics\Common.Diagnostics.csproj" />
    <ProjectReference Include="..\..\Common\Common.IO\Common.IO.csproj" />
  </ItemGroup>

</Project>
